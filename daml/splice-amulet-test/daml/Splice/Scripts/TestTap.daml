module Splice.Scripts.TestTap where

import DA.Assert
import Daml.Script
import Splice.Amulet
import Splice.AmuletRules
import Splice.Scripts.Util

testTap: Script ()
testTap = do
    DefaultAppWithUsers{..} <- setupDefaultAppWithUsers

    -- start issuing
    advanceToIssuanceWithPrice app 1.0
    runAmuletDepositBots app
    cid <- tap app alice 100.0
    Some amulet <- queryContractId @Amulet alice.primaryParty cid
    amulet.amount.initialAmount === 100.0
    config <- getAmuletConfig app
    amulet.amount.ratePerRound.rate === config.transferConfig.holdingFee.rate

    let newPrice = 3.7 : Decimal
    advanceToIssuanceWithPrice app newPrice
    runAmuletDepositBots app
    cid <- tap app alice 100.0
    Some amulet <- queryContractId @Amulet alice.primaryParty cid
    amulet.amount.initialAmount === 100.0
    config <- getAmuletConfig app
    amulet.amount.ratePerRound.rate === config.transferConfig.holdingFee.rate / newPrice

    -- check that we can't tap 100M but no more in one go
    [(rulesCid, _)] <- query @AmuletRules app.dso
    openMiningRound <- fst <$> getLatestOpenRound app
    submit (actAs alice.primaryParty <> readAs app.dso) $ exerciseCmd rulesCid AmuletRules_DevNet_Tap with
        openRound = openMiningRound
        receiver = alice.primaryParty
        amount = 100.0 * 1000.0 * 1000.0

    submitMustFail (actAs alice.primaryParty <> readAs app.dso) $ exerciseCmd rulesCid AmuletRules_DevNet_Tap with
        openRound = openMiningRound
        receiver = alice.primaryParty
        amount = 100.0 * 1000.0 * 1000.0 + 0.0000000001

    return ()
