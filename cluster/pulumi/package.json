{
    "name": "@canton-network/canton-network-pulumi-deployment",
    "version": "1.0.0",
    "main": "src/index.ts",
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@jest/globals": "^30.4.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/request": "^2.48.13",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.57.2",
        "@eslint/js": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-promise": "^7.3.0",
        "jest": "^30.4.2",
        "minimatch": "10.2.5",
        "prettier": "^3.8.4",
        "ts-jest": "^29.4.11",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "fix": "npm run format:fix && npm run lint:fix",
        "type:check": "tsc --noEmit",
        "check": "prettier --check -- *.ts && eslint --max-warnings=0 -- *.ts && npm run type:check && npm run check --workspaces --if-present",
        "format:fix": "prettier --write -- *.ts && npm run format:fix --workspaces --if-present",
        "format:check": "prettier --check -- *.ts && npm run format:check --workspaces --if-present",
        "lint:fix": "eslint --fix --max-warnings=0 -- *.ts && npm run lint:fix --workspaces --if-present",
        "lint:check": "eslint --max-warnings=0 -- *.ts && npm run lint:check --workspaces --if-present",
        "up": "PULUMI_CONFIG_PASSPHRASE= ts-node ./pulumiUp.ts",
        "down": "PULUMI_CONFIG_PASSPHRASE= ts-node ./pulumiDown.ts",
        "refresh": "PULUMI_CONFIG_PASSPHRASE= ts-node ./pulumiRefresh.ts",
        "cancel": "PULUMI_CONFIG_PASSPHRASE= ts-node ./pulumiCancel.ts",
        "test": "jest",
        "resolve-config": "ts-node ./resolvedConfigEmitter.ts"
    },
    "workspaces": [
        "common",
        "common-sv",
        "common-validator",
        "canton-network",
        "cluster",
        "gcp",
        "infra",
        "observability",
        "sv-runbook",
        "observability",
        "validator-runbook",
        "deployment",
        "operator",
        "multi-validator",
        "sv-canton",
        "validator1",
        "splitwell",
        "circleci",
        "gha",
        "policies",
        "sv"
    ],
    "dependencies": {
        "@google-cloud/sql": "^0.24.0",
        "commander": "^14.0.3"
    }
}
