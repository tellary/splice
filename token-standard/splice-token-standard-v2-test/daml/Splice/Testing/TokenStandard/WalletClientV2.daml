-- TODO(#4838): add support for allocation instruction actions


-- Tx History V2 checking utilities
-----------------------------------

type HoldingSnapshot = Map.Map (ContractId V2.Holding) V2.HoldingView

submitAndCheckTxHistory : [Party] -> SubmitOptions -> Commands b -> Script b
submitAndCheckTxHistory adminParties submitOptions action = do
  (result, _changes) <- extractAndCheckTxHistory adminParties $ submitResultAndTree submitOptions action
  pure result

extractAndCheckTxHistory : [Party] -> Script (a, TransactionTree) -> Script (a, [TransferEventsV2.EventLog_HoldingsChange])
extractAndCheckTxHistory adminParties action = do
  holdingsBefore <- snapshotHoldings adminParties
  (result, txTree) <- action
  holdingsAfter <- snapshotHoldings adminParties
  changes <- validateHoldingsChanges holdingsBefore txTree holdingsAfter
  pure (result, changes)

expectTxHistoryReasons : [TransferEventsV2.EventLog_HoldingsChange] -> [(V2.Account, [Text], Text)] -> Script ()
expectTxHistoryReasons changes expectedReasons = do
    unless (expectedReasons == actualReasons) $
      fail $ T.unlines [
        "tx history v2: expected reasons do not match actual reasons",
        "expected: " <> show expectedReasons,
        "actual:   " <> show actualReasons
      ]
  where
    actualReasons = sort $ do
      change <- mergeHoldingChangesByAdminAndAccount changes
      -- dedup on transferLegId to avoid duplicate reasons for self-transfers
      let legReasons = [ TSU.reasonFromMeta leg.meta | leg <- dedupOn (.transferLegId) change.transferLegSides ]
      pure (change.account, legReasons, TSU.reasonFromMeta change.extraArgs.meta)

snapshotHoldings : [Party] -> Script HoldingSnapshot
snapshotHoldings parties = do
  holdingsByParty <- forA parties $ \p -> do
    holdings <- queryInterface @V2.Holding p
    pure $ Map.fromList [ (cid, holding) | (cid, Some holding) <- holdings ]
  pure $ mconcat holdingsByParty

validateHoldingsChanges : HoldingSnapshot -> TransactionTree -> HoldingSnapshot -> Script [TransferEventsV2.EventLog_HoldingsChange]
validateHoldingsChanges holdingsBefore txTree holdingsAfter = do
    -- check no duplicate reporting of holding changes
    unless (unique allInputHoldingCids) $
      fail $ "duplicate input holding cids across changes: " <> show allInputHoldingCids
    unless (unique allOutputHoldingCids) $
      fail $ "duplicate output holding cids across changes: " <> show allOutputHoldingCids
    -- check invariants of individual holding changes
    forA_ changes $ \change -> do
      when (null change.transferLegSides && null change.inputHoldingCids && null change.outputHoldingCids) $
        fail $ "holding change is missing transfer legs or input/output holding cids: " <> show change
    -- check invariants of merged changes per account
    outputHoldings <- forA mergedChanges validateMergedHoldingsChange
    -- check that the changes explain the observed differences in holdings before and after the transaction
    let expectedHoldingsAfter =
          Map.filterWithKey (\cid _ -> cid `notElem` allInputHoldingCids) holdingsBefore <>
          Map.fromList (concat outputHoldings)
    unless (expectedHoldingsAfter == holdingsAfter) $
      fail $ T.unlines
        [ "holdings after change do not match expected holdings after change"
        , "expected holdings after: " <> show expectedHoldingsAfter
        , "actual holdings after:   " <> show holdingsAfter
        ]
    -- check that transfer legs are reported for both sides of the transfer for all non-admin accounts
    forA_ changes $ \change -> do
      forA_ change.transferLegSides $ \leg -> do
        -- check that the direction of burn accounts is right
        when (leg.otherside == TSU.burnAccount change.admin && leg.side == TransferEventsV2.ReceiverSide) $
          fail $ "cannot receiver from a burn account: " <> show leg
        when (leg.otherside == TSU.mintAccount change.admin && leg.side == TransferEventsV2.SenderSide) $
          fail $ "cannot send to a mint account: " <> show leg
        -- check that the other side of the transfer leg is also reported
        let otherSide = case leg.side of
              TransferEventsV2.SenderSide -> TransferEventsV2.ReceiverSide
              TransferEventsV2.ReceiverSide -> TransferEventsV2.SenderSide
        let othersideLeg =
              (leg.otherside, leg with side = otherSide; otherside = change.account)
        unless (othersideLeg `elem` allRegularTransferLegs || isNone othersideLeg._1.owner) $
          fail $ "transfer leg side " <> show leg <> " is not reported"
    -- check that total supply changes are reported via burns and mints
    unless (reportedSupplyChangeByAdmin == actualSupplyChangeByAdmin) $
      fail $ T.unlines
        [ "reported total supply changes do not match actual total supply changes"
        , "reported total supply changes: " <> show reportedSupplyChangeByAdmin
        , "actual total supply changes:   " <> show actualSupplyChangeByAdmin
        ]
    pure changes
  where
    changes = getHoldingsChangesFromTree txTree
    mergedChanges = mergeHoldingChangesByAdminAndAccount changes

    allInputHoldingCids = sort $ concatMap (.inputHoldingCids) changes
    allOutputHoldingCids = sort $ concatMap (.outputHoldingCids) changes

    reportedSupplyChangeByAdmin = Map.filter (/= 0.0) $ Map.fromListWithR (+) $ do
      change <- changes
      -- ignore changes reported on burn and mint accounts since they are not real accounts
      guard (change.account /= TSU.burnAccount change.admin && change.account /= TSU.mintAccount change.admin)
      leg <- change.transferLegSides
      case leg.side of
        TransferEventsV2.SenderSide ->  do
          guard (leg.otherside == TSU.burnAccount change.admin)
          pure (change.admin, negate leg.amount)
        TransferEventsV2.ReceiverSide ->  do
          guard (leg.otherside == TSU.mintAccount change.admin)
          pure (change.admin, leg.amount)

    actualSupplyChangeByAdmin = Map.filter (/= 0.0) $ Map.fromListWithR (+) $
      [ (holding.instrumentId.admin, negate holding.amount) | (_, holding) <- Map.toList holdingsBefore ] ++
      [ (holding.instrumentId.admin, holding.amount) | (_, holding) <- Map.toList holdingsAfter ]

    allRegularTransferLegs = do
      change <- changes
      guard (isSome change.account.owner)
      leg <- change.transferLegSides
      pure (change.account, leg)

    validateMergedHoldingsChange change
      | not (unique change.inputHoldingCids) = fail $ "duplicate input holding cids in change: " <> show change
      | not (unique change.outputHoldingCids) = fail $ "duplicate output holding cids in change: " <> show change
      | otherwise = do
          -- check input and output holdings are transient or can be read in the expected snapshots
          let checkHolding cid holding
                | holding.account /= change.account =
                    fail $ "holding cid " <> show cid <> " belongs to account " <> show holding.account <> ", expected " <> show change.account
                | holding.instrumentId.admin /= change.admin =
                    fail $ "holding cid " <> show cid <> " belongs to admin " <> show holding.instrumentId.admin <> ", expected " <> show change.admin
                | otherwise = pure ()
          debits <- forA change.inputHoldingCids $ \cid ->
            case Map.lookup cid holdingsBefore of
              None -> do
                unless (cid `elem` change.outputHoldingCids) $
                  fail $ "input holding cid " <> show cid <> " not found in before snapshot"
                pure None
              Some holding -> do
                checkHolding cid holding
                pure $ Some (holding.instrumentId, negate holding.amount)
          creditsAndOutputs <- forA change.outputHoldingCids $ \cid ->
            case Map.lookup cid holdingsAfter of
              None -> do
                unless (cid `elem` change.inputHoldingCids) $
                  fail $ "output holding cid " <> show cid <> " not found in after snapshot"
                pure None
              Some holding -> do
                checkHolding cid holding
                pure $ Some ((holding.instrumentId, holding.amount), (cid, holding))
          -- check that legs explain the balance changes of the holdings for all non-admin accounts
          let (credits, outputHoldings) = unzip (catOptionals creditsAndOutputs)
          let ignoreZeroChanges = Map.filter (/= 0.0)
          let holdingAmountChanges = ignoreZeroChanges $ Map.fromListWithR (+) (catOptionals debits ++ credits)
          let legAmountChanges = ignoreZeroChanges $ netAllocationCreditAmountsOfLegs change.admin change.transferLegSides
          unless (holdingAmountChanges == legAmountChanges || isNone change.account.owner) $
            fail $ T.unlines
              [ "holding amount changes do not match leg amount changes for account " <> show change.account
              , "holding amount changes: " <> show holdingAmountChanges
              , "leg amount changes:     " <> show legAmountChanges
              , "change: " <> show change
              ]
          pure outputHoldings

netAllocationCreditAmountsOfLegs : Party -> [TransferEventsV2.TransferLegSide] -> Map.Map V2.InstrumentId Decimal
netAllocationCreditAmountsOfLegs admin transferLegs =
    Map.fromListWithR (+) $ map legAmount transferLegs
  where
    legAmount leg =
      ( V2.InstrumentId with id = leg.instrumentId; admin
      , case leg.side of
          TransferEventsV2.SenderSide -> negate leg.amount
          TransferEventsV2.ReceiverSide -> leg.amount
      )

mergeHoldingChangesByAdminAndAccount : [TransferEventsV2.EventLog_HoldingsChange] -> [TransferEventsV2.EventLog_HoldingsChange]
mergeHoldingChangesByAdminAndAccount events =
    Map.values eventsWithAdminAndAccount
  where
    eventsWithAdminAndAccount =
      Map.fromListWithR mergeTwoHoldingChangeEvents [ ((event.admin, event.account), event) | event <- events ]
    mergeTwoHoldingChangeEvents e1 e2 =
      e1 with
        inputHoldingCids = e1.inputHoldingCids ++ e2.inputHoldingCids
        transferLegSides = e1.transferLegSides ++ e2.transferLegSides
        outputHoldingCids = e1.outputHoldingCids ++ e2.outputHoldingCids
        observers = dedupSort (e1.observers ++ e2.observers)
        extraArgs = e1.extraArgs with
          -- we dont care about the choice context here
          meta = Metadata with
            values = e1.extraArgs.meta.values <> e2.extraArgs.meta.values

getHoldingsChangesFromTree : TransactionTree -> [TransferEventsV2.EventLog_HoldingsChange]
getHoldingsChangesFromTree txTree = do
  exercised <- concatMap getExercisedFromTreeEvent txTree.rootEvents
  optionalToList $ fromAnyChoice @TransferEventsV2.EventLog exercised.argument

getExercisedFromTreeEvent : TreeEvent -> [Exercised]
getExercisedFromTreeEvent (ExercisedEvent e) = e :: concatMap getExercisedFromTreeEvent e.childEvents
getExercisedFromTreeEvent (CreatedEvent _) = []
