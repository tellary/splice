-- | Test happy path V1 allocation API calls.
--
-- Note that settlement scenarios are tested as part of the token standard DvP tests.
module Splice.Testing.Tokens.TestTokenV1.TestAllocationHappyV1 where

import DA.Assert

import Daml.Script

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationInstructionV1 qualified as V1

import Splice.Testing.Utils
import Splice.Testing.TokenStandard.RegistryApi qualified as V1
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2
import Splice.Testing.TokenStandard.MultiRegistry qualified as MultiRegistry

import Splice.Testing.Tokens.TestTokenV1.TokenStandardTestEnv (TestEnv(..), setupTest)


-- V1 API: allocate, withdraw and cancel
----------------------------------------

test_allocation_WithdrawV1 : Script ()
test_allocation_WithdrawV1 = test_allocation_withdrawCancel_generic $ \TestEnv {..} allocCid -> do
  context <- V1.getAllocation_WithdrawContext registryV1 allocCid emptyMetadata
  submit (actAs alice <> discloseMany' context.disclosures) $
    exerciseCmd allocCid V1.Allocation_Withdraw with
      extraArgs = ExtraArgs with
        context = context.choiceContext
        meta = emptyMetadata
  pure ()

test_allocation_CancelV1 : Script ()
test_allocation_CancelV1 = test_allocation_withdrawCancel_generic $ \TestEnv {..} allocCid -> do
  context <- V1.getAllocation_CancelContext registryV1 allocCid emptyMetadata
  submit (actAs provider <> actAs bob <> actAs alice <> discloseMany' context.disclosures) $
    exerciseCmd allocCid V1.Allocation_Cancel with
      extraArgs = ExtraArgs with
        context = context.choiceContext
        meta = emptyMetadata
  pure ()


-- Test V1.Allocation_ExecuteTransfer
------------------------------------

test_allocationv1_ExecuteTransfer : Script ()
test_allocationv1_ExecuteTransfer = do
  (TestEnv{..}) <- setupTest
  WalletClientV2.allocateV1 registries allocationV1
  [(aliceAllocCid, _)] <- WalletClientV2.listAllocationsV1 alice

  WalletClientV2.checkUnlockedBalance alice instrId 990.0
  WalletClientV2.checkBalance bob instrId 0.0

  context <- V1.getAllocation_TransferContext registryV1 aliceAllocCid emptyMetadata
  submit (actAs alice <> actAs bob <> actAs provider <> discloseMany' context.disclosures) $
    exerciseCmd aliceAllocCid V1.Allocation_ExecuteTransfer with
      extraArgs = ExtraArgs with
        context = context.choiceContext
        meta = emptyMetadata

  WalletClientV2.checkBalance bob instrId 10.0


-- Shared test setup
--------------------

test_allocation_withdrawCancel_generic : (TestEnv -> ContractId V1.Allocation -> Script ()) -> Script ()
test_allocation_withdrawCancel_generic mkTest = do
  testEnv@(TestEnv {..}) <- setupTest

  let checkReset = do
        WalletClientV2.checkUnlockedBalance alice instrId 1000.0
        [] <- WalletClientV2.listAllocationsV1 alice
        pure ()

  -- test v1 version
  WalletClientV2.allocateV1 registries allocationV1
  WalletClientV2.checkUnlockedBalance alice instrId 990.0
  [(allocCid, _)] <- WalletClientV2.listAllocationsV1 alice
  mkTest testEnv allocCid
  checkReset
  -- note: no test of allocation via v2 version, as that does not implement the V1 interface


-- Testing PublicFetch methods
------------------------------

test_AllocationFactoryV1_PublicFetch : Script ()
test_AllocationFactoryV1_PublicFetch = do
  -- we use the factory context to get access to the factory
  (TestEnv {..}) <- setupTest
  registryV1 <- MultiRegistry.getRegistryApiV1 registries instrId.admin
  enrichedChoice <- V1.getAllocationFactory registryV1 V1.AllocationFactory_Allocate with
    expectedAdmin = instrId.admin
    allocation = allocationV1
    inputHoldingCids = []
    requestedAt = now
    extraArgs = emptyExtraArgs

  view <- submitWithDisclosures' alice enrichedChoice.disclosures $
    exerciseCmd enrichedChoice.factoryCid V1.AllocationFactory_PublicFetch with
      expectedAdmin = instrId.admin
      actor = alice
  view === V1.AllocationFactoryView instrId.admin emptyMetadata
